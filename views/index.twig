<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="description" content="A fun, rather complicated card game.">
    <meta name="keywords" content="Card game, game, online game, cards">

    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black">
    <link rel="apple-touch-icon" href="/img/icon-192.png">
    <link rel="icon" sizes="192x192" href="/img/icon-192.png">
    <meta name="apple-mobile-web-app-title" content="Citroni">
    <meta name="mobile-web-app-capable" content="yes">
    <link href="/manifest.json" rel="manifest">

    <link href="https://fonts.googleapis.com/css?family=Pacifico|Wellfleet&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Citroni: The Game</title>
    <style>
        body {
            /* This ensures the background image covers the whole page */
            background-image: url('/img/background-start.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            color: white; /* Makes text readable against a darker background */
        }

        /* Adds a slight dark overlay so the form and text stay readable */
        body::before {
            content: "";
            position: fixed;
            top: 0; 
            left: 0;
            width: 100%; 
            height: 100%;
            background-color: rgba(0, 0, 0, 0.4); 
            z-index: -1;
        }

        #main-header {
            margin-top: 50px;
            text-shadow: 2px 2px 4px #000;
        }
    </style>
</head>
</head>
<body>
    <h3 id="main-header" class="text-center">Citroni<small class="text-muted"> The Game</small></h3>
    <div class="container">
        <div class="space"></div>
        {% for problem in problems %}
        <div class="alert alert-danger space">
            <strong>Error:</strong> {{problem}}
        </div>
        {% endfor %}
        
        {% if playerName != null %}
            <h4 class="text-success">Welcome back, {{playerName}}!</h4>
            <p>You are ready to play.</p>
            <a href="/game" type="button" class="btn btn-primary btn-lg btn-block">Join newest room</a>
            <a href="/logout" type="button" class="btn btn-danger btn-sm btn-block">Logout</a>
        {% else %}
            <p>Before you can play, you must enter a name to identify yourself.</p>
            <form action="/setName" method="POST">
                <input type="text" minlength="2" class="form-control-plaintext" name="name" placeholder="enter your name here">
                <input type="submit" class="btn btn-primary btn-lg btn-block" value="Set name">
            </form>
        {% endif %}
<div>
<p>Special cards:
<p>3 - starts from beginning</p>
<p>6 - transparent, keeps the value from last card</p>
<p>10 - burns the stack</p>
<p>Joker - burns the stack</p>
<p>4 of the same burns the stack.</p>
</p>
</div>
    </div>
    <footer class="font-small text-muted" id="footer">
        <p>By Martins Bumanis | 2020 | <a href="https://github.com/MartinsBumanis/CitroniCardGame">GitHub</a></p>
    </footer>
</body>
</html>